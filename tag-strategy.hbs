{{!< default}}

<main id="site-main" class="site-main outer aa-tag-template">
    <section class="aa-tag-hero outer">
        <div class="aa-tag-hero-inner inner">
            {{#tag}}
                <div class="aa-tag-hero-copy">
                    <span class="aa-page-eyebrow">Archivio tematico</span>
                    <h1 class="aa-page-title">{{name}}</h1>
                    {{#if description}}
                        <p class="aa-page-dek">{{description}}</p>
                    {{else}}
                        <p class="aa-page-dek">Analisi, framework e note operative su strategia, trasformazione e decisioni che devono reggere nel lavoro reale.</p>
                    {{/if}}
                </div>

                <div class="aa-tag-summary">
                    <span class="aa-page-panel-label">Dimensione archivio</span>
                    <p class="aa-page-panel-text">{{plural ../pagination.total empty="Nessun articolo pubblicato." singular="% post in archivio" plural="% post in archivio"}}</p>
                </div>
            {{/tag}}
        </div>
    </section>

    <section class="aa-page-section outer">
        <div class="inner posts">
            <div class="aa-engagement-strip is-archive">
                <div>
                    <span class="aa-page-panel-label">Perché questo archivio</span>
                    <p class="aa-engagement-copy">Qui trovi il nucleo più vicino al taglio del sito: tecnologia, trasformazione, esecuzione e adozione dell’AI letti con una prospettiva manageriale, operativa e personale.</p>
                </div>
                <a class="aa-text-link" href="/about/">Chi sono</a>
            </div>

            <div class="post-feed">
                {{#foreach posts}}
                    {{> "post-card"}}
                {{/foreach}}
            </div>

            {{pagination}}
        </div>
    </section>
</main>
