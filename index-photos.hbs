{{!< default}}

{{#contentFor "head_extra"}}
<title>Photos · {{@site.title}}</title>
<meta name="description" content="{{t "Una raccolta ordinata di fotografie pubblicate come flusso visivo autonomo, con permalink dedicati e separati dalla parte editoriale del sito."}}">
<meta property="og:title" content="Photos · {{@site.title}}">
<meta property="og:description" content="{{t "Una raccolta ordinata di fotografie pubblicate come flusso visivo autonomo, con permalink dedicati e separati dalla parte editoriale del sito."}}">
{{/contentFor}}

<main id="site-main" class="site-main aa-photos-page">
    <header class="aa-photo-page-hero outer">
        <div class="aa-photo-page-hero-inner inner">
            <div class="aa-photo-page-hero-topline">
                <span class="aa-page-eyebrow">{{t "Archivio fotografico"}}</span>
                <span class="aa-photo-page-hero-count">
                    {{plural pagination.total empty="—" singular="% fotografia" plural="% fotografie"}}
                </span>
            </div>
            <h1 class="aa-photo-page-hero-title">{{t "Photos"}}</h1>
            <p class="aa-photo-page-hero-dek">{{t "Una raccolta ordinata di fotografie pubblicate come flusso visivo autonomo, con permalink dedicati e separati dalla parte editoriale del sito."}}</p>
        </div>
    </header>

    <section class="aa-page-section outer">
        <div class="inner">
            {{#if posts}}
                <div class="aa-photo-masonry-grid" role="list">
                    {{#foreach posts}}
                        {{> "brand/photo-card-masonry"}}
                    {{/foreach}}
                </div>

                {{pagination}}
            {{else}}
                <p class="aa-home-section-copy">{{t "Non ci sono ancora fotografie in archivio."}}</p>
            {{/if}}
        </div>
    </section>
</main>
