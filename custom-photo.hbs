{{!< default}}

{{#post}}
<main id="site-main" class="site-main aa-photo-template">
    <article class="article {{post_class}} aa-single-photo">
        <header class="aa-single-photo-hero outer">
            <div class="aa-single-photo-head inner">
                <div class="aa-single-photo-meta">
                    <a class="aa-text-link" href="/photos/">Torna alle fotografie</a>
                    <span class="aa-page-eyebrow">Fotografia</span>
                    <h1 class="aa-page-title">{{title}}</h1>
                    <div class="aa-single-photo-byline">
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        {{#primary_author}}
                            <span class="bull">&bull;</span>
                            <span>{{name}}</span>
                        {{/primary_author}}
                    </div>
                    {{#if custom_excerpt}}
                        <p class="aa-page-dek">{{custom_excerpt}}</p>
                    {{else}}
                        {{#if excerpt}}
                            <p class="aa-page-dek">{{excerpt}}</p>
                        {{/if}}
                    {{/if}}

                    <div class="aa-single-photo-details">
                        <div class="aa-single-photo-detail">
                            <span class="aa-page-panel-label">Formato</span>
                            <p class="aa-page-panel-text">Scatto singolo, appunto visivo, frammento d’archivio personale.</p>
                        </div>

                        {{#if feature_image_caption}}
                            <div class="aa-single-photo-detail">
                                <span class="aa-page-panel-label">Note di campo</span>
                                <p class="aa-page-panel-text">{{feature_image_caption}}</p>
                            </div>
                        {{/if}}
                    </div>
                </div>
            </div>

            {{#if feature_image}}
                <figure class="aa-single-photo-frame gh-canvas">
                    {{> "media/picture-hero"
                        image=feature_image
                        picture_class="aa-responsive-picture aa-single-photo-picture"
                        img_class="aa-single-photo-image aa-lightbox-trigger"
                        sizes="(min-width: 1400px) 1400px, 92vw"
                        fetchpriority="high"
                        loading="eager"
                        decoding="async"
                        lightbox_src=(img_url feature_image size="xxl")
                        image_alt=feature_image_alt
                        alt=title
                    }}
                    <figcaption>Apri l’immagine a schermo intero{{#if feature_image_caption}} · {{feature_image_caption}}{{/if}}</figcaption>
                </figure>
            {{/if}}
        </header>

        <section class="gh-content gh-canvas">
            {{content}}
        </section>

        {{#get "posts" filter="id:-{{id}}+tag:hash-photos" limit="3" include="tags,authors" as |more_photos|}}
            {{#if more_photos}}
                <section class="aa-page-section outer">
                    <div class="aa-page-section-inner inner">
                        <header class="aa-home-section-heading">
                            <span class="aa-page-eyebrow">Altre fotografie</span>
                            <h2 class="aa-home-section-title">Continua a guardare</h2>
                        </header>
                        <div class="aa-photo-grid">
                            {{#foreach more_photos}}
                                {{> "brand/photo-card"}}
                            {{/foreach}}
                        </div>
                    </div>
                </section>
            {{/if}}
        {{/get}}
    </article>
</main>
{{/post}}
