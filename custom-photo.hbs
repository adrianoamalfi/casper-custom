{{!< default}}

{{#post}}
<main id="site-main" class="site-main aa-photo-template">
    <article class="article {{post_class}} aa-single-photo">

        {{!-- Back navigation --}}
        <nav class="aa-single-photo-nav outer" aria-label="{{t "Navigazione fotografia"}}">
            <div class="inner">
                <a class="aa-single-photo-back" href="/photos/">
                    <span aria-hidden="true">←</span> {{t "Fotografie"}}
                </a>
            </div>
        </nav>

        {{!-- Full-width image — the protagonist --}}
        {{#if feature_image}}
            <figure class="aa-single-photo-frame">
                {{> "media/picture-hero"
                    image=feature_image
                    picture_class="aa-responsive-picture aa-single-photo-picture"
                    img_class="aa-single-photo-image aa-lightbox-trigger"
                    sizes="(min-width: 1600px) 1600px, 96vw"
                    fetchpriority="high"
                    loading="eager"
                    decoding="async"
                    lightbox_src=(img_url feature_image size="xxl")
                    image_alt=feature_image_alt
                    alt=title
                }}
                {{#if feature_image_caption}}
                    <figcaption class="aa-single-photo-figcaption">{{feature_image_caption}}</figcaption>
                {{/if}}
            </figure>
        {{/if}}

        {{!-- Metadata below image --}}
        <header class="aa-single-photo-header outer">
            <div class="aa-single-photo-meta inner">
                <div class="aa-single-photo-meta-top">
                    <span class="aa-page-eyebrow">{{t "Fotografia"}}</span>
                    <div class="aa-single-photo-byline">
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        {{#primary_author}}
                            <span aria-hidden="true">&bull;</span>
                            <span>{{name}}</span>
                        {{/primary_author}}
                    </div>
                </div>
                <h1 class="aa-single-photo-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="aa-single-photo-caption">{{custom_excerpt}}</p>
                {{else}}
                    {{#if excerpt}}
                        <p class="aa-single-photo-caption">{{excerpt}}</p>
                    {{/if}}
                {{/if}}
            </div>
        </header>

        {{!-- Optional body content --}}
        <section class="gh-content gh-canvas">
            {{content}}
        </section>

        {{!-- Related photos --}}
        {{#get "posts" filter="id:-{{id}}+tag:hash-photos" limit="6" include="tags" as |more_photos|}}
            {{#if more_photos}}
                <section class="aa-page-section aa-single-photo-more outer">
                    <div class="inner">
                        <header class="aa-single-photo-more-header">
                            <span class="aa-page-eyebrow">{{t "Sfoglia"}}</span>
                            <h2 class="aa-home-section-title">{{t "Altre fotografie"}}</h2>
                        </header>
                        <div class="aa-photo-masonry-grid" role="list">
                            {{#foreach more_photos}}
                                {{> "brand/photo-card-masonry"}}
                            {{/foreach}}
                        </div>
                    </div>
                </section>
            {{/if}}
        {{/get}}

    </article>
</main>
{{/post}}
