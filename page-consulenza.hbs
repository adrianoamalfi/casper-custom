{{!< default}}

{{#post}}
<main id="site-main" class="site-main">
    <article class="article {{post_class}} aa-page aa-page-consulting">
        <header class="aa-page-hero outer">
            <div class="aa-page-hero-inner inner">
                <div class="aa-page-hero-copy">
                    <span class="aa-page-eyebrow">Consulenza</span>
                    <h1 class="aa-page-title">{{title}}</h1>

                    {{#if custom_excerpt}}
                        <p class="aa-page-dek">{{custom_excerpt}}</p>
                    {{else}}
                        {{#if excerpt}}
                            <p class="aa-page-dek">{{excerpt}}</p>
                        {{/if}}
                    {{/if}}
                </div>

                <aside class="aa-page-panel">
                    <span class="aa-page-panel-label">Quando ha senso coinvolgermi</span>
                    <p class="aa-page-panel-text">Quando serve mettere ordine fra visione, priorità, organizzazione e decisioni operative, soprattutto nei passaggi delicati di trasformazione.</p>
                </aside>
            </div>
        </header>

        <section class="aa-page-section outer">
            <div class="aa-page-section-inner inner">
                <div class="aa-service-grid" aria-label="Aree di intervento">
                    <article class="aa-service-card">
                        <span class="aa-service-kicker">Ambito 01</span>
                        <h2 class="aa-service-title">Strategia</h2>
                        <p class="aa-service-copy">Percorso di lavoro, modello operativo obiettivo, criteri decisionali e allineamento fra priorità, tecnologia ed esecuzione.</p>
                    </article>

                    <article class="aa-service-card">
                        <span class="aa-service-kicker">Ambito 02</span>
                        <h2 class="aa-service-title">Trasformazione</h2>
                        <p class="aa-service-copy">Disegno di iniziative, governance, priorità e meccanismi per far arrivare il cambiamento nei team e nei processi.</p>
                    </article>

                    <article class="aa-service-card">
                        <span class="aa-service-kicker">Ambito 03</span>
                        <h2 class="aa-service-title">Adozione dell’AI</h2>
                        <p class="aa-service-copy">Uso pragmatico dell’AI su processi, conoscenza, ritmo operativo e capacità interne, senza slogan e senza fumo.</p>
                    </article>
                </div>

                <div class="aa-engagement-strip">
                    <div>
                        <span class="aa-page-panel-label">Modalità di lavoro</span>
                        <p class="aa-engagement-copy">Lavoro su consulenza mirata, sessioni strategiche, momenti di allineamento e supporto su snodi decisionali che richiedono chiarezza e concretezza.</p>
                    </div>
                    <a class="aa-text-link" href="/about/">Chi sono</a>
                </div>
            </div>
        </section>

        <section class="gh-content gh-canvas">
            {{content}}
        </section>
    </article>
</main>
{{/post}}
