{{!< default}}

<main id="site-main" class="site-main outer aa-tag-template aa-scratchpad-page">
    <section class="aa-tag-hero outer">
        <div class="aa-tag-hero-inner inner">
            <div class="aa-tag-hero-copy">
                <span class="aa-page-eyebrow">Archivio di appunti, guide e esperimenti tecnici</span>
                <h1 class="aa-page-title">Tech Scratchpad</h1>
                <p class="aa-page-dek">Guide tecniche, appunti, esperimenti e consigli pratici su sviluppo, architetture e tecnologie.</p>
            </div>

            <div class="aa-tag-summary aa-scratchpad-summary">
                <span class="aa-page-panel-label">Segnali rapidi</span>
                <ul class="aa-page-metadata aa-scratchpad-summary-list">
                    <li>{{plural pagination.total empty="Nessuna entry pubblicata." singular="% entry pubblicata" plural="% entry pubblicate"}}</li>
                    <li>Ogni scheda mette in evidenza formato, stato e stack in un colpo d'occhio.</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="aa-page-section outer">
        <div class="inner posts">
            <ol class="aa-scratchpad-list">
                {{#foreach posts}}
                <li class="aa-scratchpad-item">
                    <time class="aa-scratchpad-item-date" datetime="{{date format="YYYY-MM-DD"}}">
                        <span class="aa-scratchpad-item-date-day">{{date format="DD MMM"}}</span>
                        <span class="aa-scratchpad-item-date-year">{{date format="YYYY"}}</span>
                    </time>
                    <div class="aa-scratchpad-item-body">
                        <a class="aa-scratchpad-item-title" href="{{url}}">{{title}}</a>
                        <div class="aa-scratchpad-item-taxonomy">
                            {{> "brand/scratchpad-badges"}}
                            {{> "brand/scratchpad-stacks"}}
                        </div>
                    </div>
                    {{#if reading_time}}
                        <span class="aa-scratchpad-item-time">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                    {{/if}}
                </li>
                {{/foreach}}
            </ol>

            {{pagination}}
        </div>
    </section>
</main>
