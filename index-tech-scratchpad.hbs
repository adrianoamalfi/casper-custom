{{!< default}}

<main id="site-main" class="site-main outer aa-tag-template">
    <section class="aa-tag-hero outer">
        <div class="aa-tag-hero-inner inner">
            <div class="aa-tag-hero-copy">
                <span class="aa-page-eyebrow">Archivio operativo</span>
                <h1 class="aa-page-title">Tech Scratchpad</h1>
                <p class="aa-page-dek">Appunti tecnici, prove, configurazioni e note di lavoro raccolte come un taccuino pratico, più vicino al laboratorio che al saggio finito.</p>
            </div>

            <div class="aa-tag-summary">
                <span class="aa-page-panel-label">Dimensione archivio</span>
                <p class="aa-page-panel-text">{{plural pagination.total empty="Nessun appunto pubblicato." singular="% appunto pubblicato" plural="% appunti pubblicati"}}</p>
            </div>
        </div>
    </section>

    <section class="aa-page-section outer">
        <div class="inner posts">
            <div class="aa-engagement-strip is-archive">
                <div>
                    <span class="aa-page-panel-label">Formato</span>
                    <p class="aa-engagement-copy">Un taccuino di lavoro per tenere traccia di esperimenti, fix, configurazioni e scorciatoie utili. Materiale più grezzo, ma immediatamente riusabile.</p>
                </div>
            </div>

            <div class="post-feed">
                {{#foreach posts}}
                    {{> "post-card"}}
                {{/foreach}}
            </div>

            {{pagination}}
        </div>
    </section>
</main>
