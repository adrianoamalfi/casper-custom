{{!< default}}

{{!--

There are two error files in this theme, one for 404s and one for all other errors.
This file is the former, and handles all 404 Page Not Found errors.

The 404 error is the most common error that a visitor might see, for example when
following a broken link

Keep this template as lightweight as you can!

--}}

<section class="outer error-content aa-404-fullpage">
    <div class="inner aa-404-fullpage-inner">
        <section class="error-message aa-404-shell">
            <span class="aa-404-eyebrow">Pagina evaporata</span>
            <div class="aa-404-visual" aria-hidden="true">
                <span class="aa-404-code">{{statusCode}}</span>
            </div>
            <div class="aa-404-copy">
                <h1 class="error-code">Qui non c'è nulla.</h1>
                <p class="error-description">
                    Il link ha preso una scorciatoia discutibile. La buona notizia è che puoi tornare alla home o cercare quello che volevi davvero.
                </p>
                <div class="aa-404-actions">
                    <a class="error-link aa-404-primary-link" href="{{@site.url}}">Vai alla home</a>
                    <button class="aa-404-search gh-search gh-icon-btn" type="button" data-ghost-search aria-label="Cerca nel sito">
                        {{> "icons/search"}}
                        <span>Cerca</span>
                    </button>
                </div>
            </div>
        </section>
    </div>
</section>
