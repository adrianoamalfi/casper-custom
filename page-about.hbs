{{!< default}}

{{#post}}
<main id="site-main" class="site-main">
    <article class="article {{post_class}} aa-page aa-page-about">
        <header class="aa-page-hero outer">
            <div class="aa-page-hero-inner inner">
                <div class="aa-page-hero-copy">
                    <span class="aa-page-eyebrow">Chi sono</span>
                    <h1 class="aa-page-title">{{title}}</h1>

                    {{#if custom_excerpt}}
                        <p class="aa-page-dek">{{custom_excerpt}}</p>
                    {{else}}
                        {{#if excerpt}}
                            <p class="aa-page-dek">{{excerpt}}</p>
                        {{/if}}
                    {{/if}}

                    <div class="aa-page-actions">
                        <a class="aa-primary-button" href="/consulenza/">Lavoriamo insieme</a>
                        <a class="aa-text-link" href="/tag/strategy/">Leggi i contenuti</a>
                    </div>
                </div>

                <aside class="aa-page-panel">
                    <span class="aa-page-panel-label">In breve</span>
                    <p class="aa-page-panel-text">Mi occupo di strategia ICT, trasformazione digitale e adozione pragmatica dell’AI, con un approccio che tiene insieme pensiero, scrittura ed esecuzione.</p>
                    <ul class="aa-page-metadata" aria-label="Temi chiave">
                        <li>Modello operativo e organizzazione</li>
                        <li>Innovazione, digitale e AI</li>
                        <li>Scrittura come strumento di chiarezza</li>
                    </ul>
                </aside>
            </div>
        </header>

        <section class="aa-page-section outer">
            <div class="aa-page-section-inner inner">
                <div class="aa-signal-grid" aria-label="Come lavoro">
                    <article class="aa-signal-card">
                        <span class="aa-signal-kicker">Approccio</span>
                        <h2 class="aa-signal-title">Chiarezza prima del rumore</h2>
                        <p class="aa-signal-copy">Cerco di ridurre complessità, esplicitare tradeoff e trasformare ambiguità in scelte comprensibili e sostenibili.</p>
                    </article>

                    <article class="aa-signal-card">
                        <span class="aa-signal-kicker">Metodo</span>
                        <h2 class="aa-signal-title">Disciplina di esecuzione</h2>
                        <p class="aa-signal-copy">Mi interessano decisioni che reggono quando si passa all'operatività: governance, priorità, responsabilità e ritmo di lavoro.</p>
                    </article>

                    <article class="aa-signal-card">
                        <span class="aa-signal-kicker">Voce</span>
                        <h2 class="aa-signal-title">Prospettiva editoriale</h2>
                        <p class="aa-signal-copy">Uso la scrittura per capire meglio quello che osservo: non come ornamento, ma come strumento per dare forma alle idee.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="gh-content gh-canvas">
            {{content}}
        </section>
    </article>
</main>
{{/post}}
