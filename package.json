{
    "name": "casper-adriano",
    "description": "Casper Adriano - A custom theme forked from Casper, created by Adriano Amalfi.",
    "demo": "https://demo.ghost.io",
    "version": "5.9.3",
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "screenshots": {
        "desktop": "assets/screenshot-desktop.jpg",
        "mobile": "assets/screenshot-mobile.jpg"
    },
    "scripts": {
        "dev": "gulp",
        "zip": "gulp zip",
        "test": "gscan .",
        "test:ci": "gscan --fatal --verbose .",
        "pretest": "gulp build",
        "preship": "yarn test",
        "ship": "node -e \"const { execSync } = require('child_process'); const status = execSync('git status --porcelain').toString().trim(); if (!status) { execSync('yarn version && git push --follow-tags', { stdio: 'inherit' }); } else { console.error('Uncommitted changes found. Please commit or stash your changes before shipping.'); process.exit(1); }\"",
        "ship-win": "node -e \"const { execSync } = require('child_process'); const status = execSync('git status --porcelain').toString().trim(); if (!status) { execSync('yarn version && git push --follow-tags', { stdio: 'inherit' }); } else { console.error('Uncommitted changes found. Please commit or stash your changes before shipping.'); process.exit(1); }\"",
        "postship": "git fetch && gulp release",
        "update-browserslist": "npx update-browserslist-db@latest"
    },
    "author": {
        "name": "Adriano Amalfi",
        "email": "adrianoamalfi@gmail.com",
        "url": "https://adrianoamalfi.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/adrianoamalfi/Casper"
    },
    "bugs": "https://github.com/adrianoamalfi/Casper/issues",
    "contributors": [
        {
            "name": "Adriano Amalfi",
            "email": "adrianoamalfi@gmail.com",
            "url": "https://adrianoamalfi.com"
        }
    ],
    "gpm": {
        "type": "theme",
        "categories": [
            "Minimal",
            "Magazine"
        ]
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme",
        "casper-adriano",
        "adriano-amalfi"
    ],
    "devDependencies": {
        "@tryghost/release-utils": "0.8.1",
        "autoprefixer": "10.4.13",
        "beeper": "2.1.0",
        "conventional-changelog-cli": "^5.0.0",
        "conventional-github-releaser": "^3.1.5",
        "conventional-recommended-bump": "^11.0.0",
        "cssnano": "5.1.15",
        "dotenv": "^16.4.7",
        "execa": "^9.5.2",
        "gscan": "4.49.1",
        "gulp": "4.0.2",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "9.0.1",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "inquirer": "8.2.4",
        "postcss": "8.4.21",
        "postcss-color-mod-function": "3.0.3",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.0"
    },
    "browserslist": [
        "defaults"
    ],
    "config": {
        "posts_per_page": 25,
        "image_sizes": {
            "xxs": {
                "width": 30
            },
            "xs": {
                "width": 100
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 600
            },
            "l": {
                "width": 1000
            },
            "xl": {
                "width": 2000
            }
        },
        "card_assets": true,
        "custom": {
            "navigation_layout": {
                "type": "select",
                "options": [
                    "Logo on cover",
                    "Logo in the middle",
                    "Stacked"
                ],
                "default": "Logo on cover"
            },
            "title_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Modern sans-serif"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Elegant serif"
            },
            "show_cookie_banner": {
                "type": "boolean",
                "default": true
            },
            "show_linkedin_button": {
                "type": "boolean",
                "default": true
            },
            "linkedin_account": {
                "type": "text",
                "default": "adrianoamalfi",
                "visibility": "show_linkedin_button:true"
            },
            "show_publication_cover": {
                "type": "boolean",
                "default": true,
                "group": "homepage"
            },
            "header_style": {
                "type": "select",
                "options": [
                    "Center aligned",
                    "Left aligned",
                    "Hidden"
                ],
                "default": "Center aligned",
                "group": "homepage"
            },
            "feed_layout": {
                "type": "select",
                "options": [
                    "Classic",
                    "Grid",
                    "List"
                ],
                "default": "Classic",
                "group": "homepage"
            },
            "color_scheme": {
                "type": "select",
                "options": [
                    "Light",
                    "Dark",
                    "Auto"
                ],
                "default": "Light"
            },
            "post_image_style": {
                "type": "select",
                "options": [
                    "Wide",
                    "Full",
                    "Small",
                    "Hidden"
                ],
                "default": "Wide",
                "group": "post"
            },
            "email_signup_text": {
                "type": "text",
                "default": "Sign up for more like this.",
                "group": "post"
            },
            "show_recent_posts_footer": {
                "type": "boolean",
                "default": true,
                "group": "post"
            },
            "show_progress_bar_on_post": {
                "type": "boolean",
                "default": true,
                "group": "post"
            },
            "use_prismjs_syntax_highlighting": {
                "type": "boolean",
                "default": true,
                "group": "post"
            }
        }
    },
    "renovate": {
        "extends": [
            "@tryghost:theme"
        ]
    },
    "dependencies": {
        "caniuse-lite": "^1.0.30001707"
    }
}
