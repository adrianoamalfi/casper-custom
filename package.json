{
    "name": "casper-custom",
    "description": "Casper fork personalizzato per adrianoamalfi.com",
    "demo": "https://adrianoamalfi.com",
    "version": "5.12.1-custom.1",
    "engines": {
        "ghost": ">=5.0.0",
        "node": ">=22.12.0"
    },
    "license": "MIT",
    "screenshots": {
        "desktop": "assets/screenshot-desktop-custom.jpg",
        "mobile": "assets/screenshot-mobile-custom.jpg"
    },
    "scripts": {
        "dev": "gulp",
        "sync-upstream": "bash scripts/sync-upstream.sh",
        "zip": "gulp zip",
        "build": "gulp build",
        "test": "gscan --zip dist/casper-custom.zip",
        "test:ci": "gscan --fatal --verbose --zip dist/casper-custom.zip",
        "pretest": "pnpm zip",
        "pretest:ci": "pnpm zip",
        "preship": "pnpm test",
        "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then pnpm version && git push --follow-tags; else echo \"Uncomitted changes found.\" && exit 1; fi",
        "postship": "git fetch && gulp release"
    },
    "packageManager": "pnpm@11.5.2",
    "author": {
        "name": "Adriano Amalfi",
        "email": "info@adrianoamalfi.com",
        "url": "https://adrianoamalfi.com"        
    },
    "gpm": {
        "type": "theme",
        "categories": [
            "Minimal",
            "Magazine", 
            "Customizable",
            "Personal",
            "Responsive",
            "SEO Friendly",
            "Fast Loading",
            "Accessibility Ready"
        ]
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme",
        "casper",
        "custom"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/adrianoamalfi/casper-custom.git"
    },
    "bugs": "https://github.com/adrianoamalfi/casper-custom",
    "contributors": "https://github.com/adrianoamalfi/casper-custom/graphs/contributors",
    "devDependencies": {
        "@highlightjs/cdn-assets": "^11.11.1",
        "@tryghost/release-utils": "0.8.1",
        "@tryghost/theme-translations": "0.0.21",
        "autoprefixer": "10.5.0",
        "beeper": "2.1.0",
        "cssnano": "8.0.1",
        "gscan": "6.2.1",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "6.1.0",
        "inquirer": "14.0.2",
        "postcss": "8.5.15",
        "postcss-color-mod-function": "4.1.1",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4"
    },
    "browserslist": [
        "defaults"
    ],
    "config": {
        "posts_per_page": 10,
        "image_sizes": {
            "xxs": {
                "width": 30
            },
            "xs": {
                "width": 100
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 600
            },
            "l": {
                "width": 1000
            },
            "xl": {
                "width": 2000
            },
            "xxl": {
                "width": 2400
            }
        },
        "card_assets": true,
        "custom": {
            "navigation_layout": {
                "type": "select",
                "options": [
                    "Logo on cover",
                    "Logo in the middle",
                    "Stacked"
                ],
                "default": "Logo on cover",
                "group": "homepage"
            },
            "title_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Elegant serif",
                "group": "homepage"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Elegant serif",
                "group": "homepage"
            },
            "brand_footer_linkedin_url": {
                "type": "text",
                "default": "https://www.linkedin.com/comm/mynetwork/discovery-see-all?usecase=PEOPLE_FOLLOWS&followMember=adrianoamalfi",
                "group": "homepage"
            },
            "brand_footer_github_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "brand_footer_huggingface_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "brand_footer_instagram_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "brand_footer_facebook_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "brand_footer_x_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "brand_footer_threads_url": {
                "type": "text",
                "default": "",
                "group": "homepage"
            },
            "show_publication_cover": {
                "type": "boolean",
                "default": true,
                "group": "homepage"
            },
            "header_style": {
                "type": "select",
                "options": [
                    "Center aligned",
                    "Left aligned",
                    "Hidden"
                ],
                "default": "Center aligned",
                "group": "homepage"
            },
            "feed_layout": {
                "type": "select",
                "options": [
                    "Classic",
                    "Grid",
                    "List"
                ],
                "default": "Classic",
                "group": "homepage"
            },
            "color_scheme": {
                "type": "select",
                "options": [
                    "Light",
                    "Dark",
                    "Auto"
                ],
                "default": "Light",
                "group": "homepage"
            },
            "post_image_style": {
                "type": "select",
                "options": [
                    "Wide",
                    "Full",
                    "Small",
                    "Hidden"
                ],
                "default": "Wide",
                "group": "post"
            },
            "email_signup_text": {
                "type": "text",
                "default": "Iscriviti per ricevere nuovi articoli come questo.",
                "group": "post"
            },
            "post_cta_title": {
                "type": "text",
                "default": "Continua l'esplorazione",
                "group": "post"
            },
            "post_cta_copy": {
                "type": "text",
                "default": "Una selezione di percorsi, profilo professionale e possibilità di confronto collegati ai temi trattati nel sito.",
                "group": "post"
            },
            "post_cta_primary_url": {
                "type": "text",
                "default": "/contact-me/",
                "group": "post"
            },
            "show_recent_posts_footer": {
                "type": "boolean",
                "default": true,
                "group": "post"
            }
        }
    }
}
