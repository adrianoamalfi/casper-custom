{
    "name": "casper-custom",
    "description": "Casper fork personalizzato per adrianoamalfi.com",
    "demo": "https://adrianoamalfi.com",
    "version": "5.10.4-custom.1",
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "screenshots": {
        "desktop": "assets/screenshot-desktop.jpg",
        "mobile": "assets/screenshot-mobile.jpg"
    },
    "scripts": {
        "dev": "gulp",
        "zip": "gulp zip",
        "test": "gscan .",
        "test:ci": "gscan --fatal --verbose .",
        "pretest": "gulp build",
        "preship": "yarn test",
        "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then yarn version && git push --follow-tags; else echo \"Uncomitted changes found.\" && exit 1; fi",
        "postship": "git fetch && gulp release"
    },
    "author": {
        "name": "Ghost Foundation",
        "email": "hello@ghost.org",
        "url": "https://ghost.org/"
    },
    "gpm": {
        "type": "theme",
        "categories": [
            "Minimal",
            "Magazine"
        ]
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/TryGhost/Casper.git"
    },
    "bugs": "https://github.com/TryGhost/Casper/issues",
    "contributors": "https://github.com/TryGhost/Casper/graphs/contributors",
    "devDependencies": {
        "@highlightjs/cdn-assets": "^11.11.1",
        "@tryghost/release-utils": "0.8.1",
        "@tryghost/theme-translations": "~0.0.16",
        "autoprefixer": "10.4.24",
        "beeper": "2.1.0",
        "cssnano": "7.1.2",
        "gscan": "5.2.4",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "6.1.0",
        "highlight.js": "11.11.1",
        "inquirer": "13.2.2",
        "postcss": "8.5.6",
        "postcss-color-mod-function": "4.1.1",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.3"
    },
    "browserslist": [
        "defaults"
    ],
    "config": {
        "posts_per_page": 25,
        "image_sizes": {
            "xxs": {
                "width": 30
            },
            "xs": {
                "width": 100
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 600
            },
            "l": {
                "width": 1000
            },
            "xl": {
                "width": 2000
            }
        },
        "card_assets": true,
        "custom": {
            "navigation_layout": {
                "type": "select",
                "options": [
                    "Logo on cover",
                    "Logo in the middle",
                    "Stacked"
                ],
                "default": "Logo on cover"
            },
            "title_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Elegant serif"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Elegant serif"
            },
            "brand_footer_name": {
                "type": "text",
                "default": "Adriano Amalfi",
                "group": "brand"
            },
            "brand_footer_role": {
                "type": "text",
                "default": "Strategia ICT · Trasformazione digitale",
                "group": "brand"
            },
            "global_primary_cta_label": {
                "type": "text",
                "default": "Lavoriamo insieme",
                "group": "brand"
            },
            "global_primary_cta_url": {
                "type": "text",
                "default": "/consulenza/",
                "group": "brand"
            },
            "global_secondary_cta_label": {
                "type": "text",
                "default": "Chi sono",
                "group": "brand"
            },
            "global_secondary_cta_url": {
                "type": "text",
                "default": "/about/",
                "group": "brand"
            },
            "show_publication_cover": {
                "type": "boolean",
                "default": true,
                "group": "homepage"
            },
            "header_style": {
                "type": "select",
                "options": [
                    "Center aligned",
                    "Left aligned",
                    "Hidden"
                ],
                "default": "Center aligned",
                "group": "homepage"
            },
            "feed_layout": {
                "type": "select",
                "options": [
                    "Classic",
                    "Grid",
                    "List"
                ],
                "default": "Classic",
                "group": "homepage"
            },
            "home_topics_title": {
                "type": "text",
                "default": "Un modo semplice per orientarsi",
                "group": "homepage"
            },
            "home_topics_description": {
                "type": "text",
                "default": "Qui i contenuti non sono pensati solo come flusso cronologico. Ho organizzato il sito in tre percorsi ricorrenti, per aiutare chi arriva a leggere partendo dal tema più vicino ai propri interessi.",
                "group": "homepage"
            },
            "home_topic_1_label": {
                "type": "text",
                "default": "Tecnologia e digitale",
                "group": "homepage"
            },
            "home_topic_1_description": {
                "type": "text",
                "default": "Tecnologie emergenti, architetture digitali, AI e strumenti letti con attenzione a impatti, limiti, maturità e utilità concreta.",
                "group": "homepage"
            },
            "home_topic_1_url": {
                "type": "text",
                "default": "/tag/strategy/",
                "group": "homepage"
            },
            "home_topic_2_label": {
                "type": "text",
                "default": "Innovazione e cambiamento",
                "group": "homepage"
            },
            "home_topic_2_description": {
                "type": "text",
                "default": "Strategia, esecuzione, governance e trasformazione organizzativa: il lato meno retorico e più operativo del cambiamento.",
                "group": "homepage"
            },
            "home_topic_2_url": {
                "type": "text",
                "default": "/tag/transformation/",
                "group": "homepage"
            },
            "home_topic_3_label": {
                "type": "text",
                "default": "Taccuino tecnico",
                "group": "homepage"
            },
            "home_topic_3_description": {
                "type": "text",
                "default": "Note pratiche, how-to, configurazioni, prove e piccoli esperimenti: la parte più concreta e laboratoriale del sito.",
                "group": "homepage"
            },
            "home_topic_3_url": {
                "type": "text",
                "default": "/tag/ai/",
                "group": "homepage"
            },
            "home_visual_title": {
                "type": "text",
                "default": "Fotografie e immagini generate",
                "group": "homepage"
            },
            "home_visual_description": {
                "type": "text",
                "default": "Accanto alla scrittura tengo un archivio visivo separato. Da una parte le fotografie che scatto, dall’altra le immagini generate con l’AI come spazio di esplorazione più libero e sperimentale.",
                "group": "homepage"
            },
            "home_photos_label": {
                "type": "text",
                "default": "Fotografie",
                "group": "homepage"
            },
            "home_photos_title": {
                "type": "text",
                "default": "Scatti personali",
                "group": "homepage"
            },
            "home_photos_url": {
                "type": "text",
                "default": "/photos/",
                "group": "homepage"
            },
            "home_ai_label": {
                "type": "text",
                "default": "Immagini generate",
                "group": "homepage"
            },
            "home_ai_title": {
                "type": "text",
                "default": "Immagini generate con l’AI",
                "group": "homepage"
            },
            "home_ai_url": {
                "type": "text",
                "default": "/ai-art/",
                "group": "homepage"
            },
            "color_scheme": {
                "type": "select",
                "options": [
                    "Light",
                    "Dark",
                    "Auto"
                ],
                "default": "Light"
            },
            "post_image_style": {
                "type": "select",
                "options": [
                    "Wide",
                    "Full",
                    "Small",
                    "Hidden"
                ],
                "default": "Wide",
                "group": "post"
            },
            "email_signup_text": {
                "type": "text",
                "default": "Iscriviti per ricevere nuovi articoli come questo.",
                "group": "post"
            },
            "post_cta_eyebrow": {
                "type": "text",
                "default": "Dopo l'articolo",
                "group": "post"
            },
            "post_cta_title": {
                "type": "text",
                "default": "Se questo tema ti interessa, puoi approfondire.",
                "group": "post"
            },
            "post_cta_copy": {
                "type": "text",
                "default": "Puoi continuare la lettura nel sito, capire meglio il mio approccio oppure usare questo articolo come punto di partenza per una conversazione di lavoro.",
                "group": "post"
            },
            "author_box_fallback_bio": {
                "type": "text",
                "default": "Scrivo di strategia, trasformazione digitale, innovazione e adozione pragmatica dell’AI con un taglio personale, operativo ed editoriale.",
                "group": "post"
            },
            "show_recent_posts_footer": {
                "type": "boolean",
                "default": true,
                "group": "post"
            }
        }
    },
    "renovate": {
        "extends": [
            "@tryghost:theme",
            "github>TryGhost/Themes:packages/theme-translations/renovate-config"
        ]
    }
}
