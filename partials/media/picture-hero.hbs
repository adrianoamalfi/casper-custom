<picture{{#if picture_class}} class="{{picture_class}}"{{/if}}>
    <source
        srcset="{{img_url image size="s" format="avif"}} 300w,
                {{img_url image size="m" format="avif"}} 600w,
                {{img_url image size="l" format="avif"}} 1000w,
                {{img_url image size="xl" format="avif"}} 2000w,
                {{img_url image size="xxl" format="avif"}} 2400w"
        sizes="{{sizes}}"
        type="image/avif"
    >
    <source
        srcset="{{img_url image size="s" format="webp"}} 300w,
                {{img_url image size="m" format="webp"}} 600w,
                {{img_url image size="l" format="webp"}} 1000w,
                {{img_url image size="xl" format="webp"}} 2000w,
                {{img_url image size="xxl" format="webp"}} 2400w"
        sizes="{{sizes}}"
        type="image/webp"
    >
    <img
        {{#if img_class}}class="{{img_class}}"{{/if}}
        srcset="{{img_url image size="s"}} 300w,
                {{img_url image size="m"}} 600w,
                {{img_url image size="l"}} 1000w,
                {{img_url image size="xl"}} 2000w,
                {{img_url image size="xxl"}} 2400w"
        sizes="{{sizes}}"
        src="{{img_url image size="xl"}}"
        {{#if fetchpriority}}fetchpriority="{{fetchpriority}}"{{/if}}
        loading="{{#if loading}}{{loading}}{{else}}lazy{{/if}}"
        decoding="{{#if decoding}}{{decoding}}{{else}}async{{/if}}"
        alt="{{#if image_alt}}{{image_alt}}{{else}}{{alt}}{{/if}}"
        {{#if lightbox_src}}data-pswp-src="{{lightbox_src}}"{{/if}}
    />
</picture>
