<picture{{#if picture_class}} class="{{picture_class}}"{{/if}}>
    <source
        srcset="{{img_url image size="xxs" format="avif"}} 30w,
                {{img_url image size="xs" format="avif"}} 100w,
                {{img_url image size="s" format="avif"}} 300w,
                {{img_url image size="m" format="avif"}} 600w"
        sizes="{{sizes}}"
        type="image/avif"
    >
    <source
        srcset="{{img_url image size="xxs" format="webp"}} 30w,
                {{img_url image size="xs" format="webp"}} 100w,
                {{img_url image size="s" format="webp"}} 300w,
                {{img_url image size="m" format="webp"}} 600w"
        sizes="{{sizes}}"
        type="image/webp"
    >
    <img
        {{#if img_class}}class="{{img_class}}"{{/if}}
        srcset="{{img_url image size="xxs"}} 30w,
                {{img_url image size="xs"}} 100w,
                {{img_url image size="s"}} 300w,
                {{img_url image size="m"}} 600w"
        sizes="{{sizes}}"
        src="{{img_url image size="s"}}"
        {{#if width}}width="{{width}}"{{/if}}
        {{#if height}}height="{{height}}"{{/if}}
        loading="{{#if loading}}{{loading}}{{else}}lazy{{/if}}"
        decoding="{{#if decoding}}{{decoding}}{{else}}async{{/if}}"
        alt="{{alt}}"
    />
</picture>
