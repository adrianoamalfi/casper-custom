{{!-- 
    Photo Card Partial
    ----------------
    This template renders a card-style article preview with a featured image.
    It's used in article lists and supports responsive images with multiple formats.

    Context:
    - post_class: Classes for styling the article
    - feature_image: The post's featured image URL
    - url: The post's URL
    - title: The post's title
    - featured: Boolean indicating if the post is featured
    - feature_image_alt: Alt text for the featured image
--}}
<article class="photo-card {{post_class}}" role="article">
    {{#if feature_image}}
    {{!-- Image link wrapper with accessibility attributes --}}
    <a class="photo-card-image-link" 
       href="{{url}}" 
       aria-label="{{title}}"
       tabindex="0">
        
        {{!-- Responsive picture element with AVIF and WebP support --}}
        <picture>
            {{!-- AVIF format source --}}
            <source 
                srcset="{{img_url feature_image size="s" format="avif"}} 300w,
                        {{img_url feature_image size="m" format="avif"}} 600w,
                        {{img_url feature_image size="l" format="avif"}} 1000w"
                sizes="(max-width: 600px) 95vw,
                       (max-width: 1000px) 45vw,
                       (max-width: 1400px) 30vw,
                       25vw"
                type="image/avif"
                {{#has index="0"}}fetchpriority="high"{{/has}}>
            {{!-- WebP format source --}}
            <source 
                srcset="{{img_url feature_image size="s" format="webp"}} 300w,
                        {{img_url feature_image size="m" format="webp"}} 600w,
                        {{img_url feature_image size="l" format="webp"}} 1000w"
                sizes="(max-width: 600px) 95vw,
                       (max-width: 1000px) 45vw,
                       (max-width: 1400px) 30vw,
                       25vw"
                type="image/webp"
                {{#has index="0"}}fetchpriority="high"{{/has}}>
            {{!-- Fallback image --}}
            <img class="photo-card-image"
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 600w,
                        {{img_url feature_image size="l"}} 1000w"
                sizes="(max-width: 600px) 95vw,
                       (max-width: 1000px) 45vw,
                       (max-width: 1400px) 30vw,
                       25vw"
                src="{{img_url feature_image size="m"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                {{#has index="0"}}fetchpriority="high" loading="eager"{{else}}loading="lazy"{{/has}}
                decoding="async">
        </picture>
        
        {{!-- Featured post badge --}}
        {{#if featured}}
            <div class="photo-card-badge">
                {{> "icons/star"}}
                <span>In evidenza</span>
            </div>
        {{/if}}
        {{!-- Post title --}}
        <div class="photo-card-content">
            <h2 class="photo-card-title">{{title}}</h2>
        </div>
    </a>
    {{/if}}
</article>
