<article class="photo-card {{post_class}}" role="article">
    {{#if feature_image}}
    <a class="photo-card-image-link" 
       href="{{url}}" 
       aria-label="{{title}}"
       tabindex="0">
        <img class="photo-card-image"
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w"
            sizes="(max-width: 600px) 95vw,
                   (max-width: 1000px) 45vw,
                   (max-width: 1400px) 30vw,
                   25vw"
            src="{{img_url feature_image size="m"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
            decoding="async">
        {{#if featured}}
            <div class="photo-card-badge">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16">
                    <path fill="currentColor" d="M12 .587l3.668 7.431 8.332 1.21-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.21z"/>
                </svg>
                <span>In evidenza</span>
            </div>
        {{/if}}
        <div class="photo-card-content">
            <h2 class="photo-card-title">{{title}}</h2>
        </div>
    </a>
    {{/if}}
</article>
