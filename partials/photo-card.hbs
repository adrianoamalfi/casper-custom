<article class="photo-card {{post_class}}">
    {{#if feature_image}}
    <a class="photo-card-image-link" href="{{url}}">
        <img class="photo-card-image"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
            decoding="async">
        {{#if featured}}
        <span class="photo-card-featured-badge">In evidenza ⭐</span>
        {{/if}}
    </a>
    {{/if}}

    <div class="photo-card-content">
        <h2 class="photo-card-title">
            <a href="{{url}}">{{title}}</a>
        </h2>
        {{#if primary_tag}}
        <span class="photo-card-tag">{{primary_tag.name}}</span>
        {{/if}}
    </div>
</article>
