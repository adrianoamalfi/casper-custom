<article class="photo-card {{post_class}}" role="article">
    {{#if feature_image}}
    <a class="photo-card-image-link" 
       href="{{url}}" 
       aria-label="{{title}}"
       tabindex="0">
        <img class="photo-card-image"
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w"
            sizes="(max-width: 600px) 95vw,
                   (max-width: 1000px) 45vw,
                   (max-width: 1400px) 30vw,
                   25vw"
            src="{{img_url feature_image size="m"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
            decoding="async">
        <div class="photo-card-content">
            <h2 class="photo-card-title">{{title}}</h2>
            {{#if primary_tag}}
                <span class="photo-card-tag">{{primary_tag.name}}</span>
            {{/if}}
        </div>
    </a>
    {{/if}}
</article>
