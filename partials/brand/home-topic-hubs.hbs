<section class="aa-home-clusters outer">
    <div class="aa-home-clusters-inner inner">
        {{#get "posts" filter="tag:intelligenza-artificiale" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Intelligenza Artificiale</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/intelligenza-artificiale/">Archivio Intelligenza Artificiale</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:innovazione" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Innovazione e cambiamento</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/innovazione/">Archivio Innovazione</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:hash-tech-scratchpad" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Taccuino operativo</h2>
                        </div>
                        <a class="aa-text-link" href="/tech-scratchpad/">Archivio Guide</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}
    </div>
</section>
