<section class="aa-home-topics outer">
    <div class="aa-home-topics-inner inner">
        <header class="aa-home-section-heading">
            <span class="aa-page-eyebrow">Percorsi editoriali</span>
            <h2 class="aa-home-section-title">Un modo semplice per orientarsi</h2>
            <p class="aa-home-section-copy">Qui i contenuti non sono pensati solo come flusso cronologico. Ho organizzato il sito in tre percorsi ricorrenti, per aiutare chi arriva a leggere partendo dal tema più vicino ai propri interessi.</p>
        </header>

        <div class="aa-topic-hub-grid">
            <a class="aa-topic-hub" href="/tag/strategy/">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">Tecnologia e digitale</h3>
                <p class="aa-topic-hub-copy">Tecnologie emergenti, architetture digitali, AI e strumenti letti con attenzione a impatti, limiti, maturità e utilità concreta.</p>
            </a>

            <a class="aa-topic-hub" href="/tag/transformation/">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">Innovazione e cambiamento</h3>
                <p class="aa-topic-hub-copy">Strategia, esecuzione, governance e trasformazione organizzativa: il lato meno retorico e più operativo del cambiamento.</p>
            </a>

            <a class="aa-topic-hub" href="/tag/ai/">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">Taccuino tecnico</h3>
                <p class="aa-topic-hub-copy">Note pratiche, how-to, configurazioni, prove e piccoli esperimenti: la parte più concreta e laboratoriale del sito.</p>
            </a>
        </div>
    </div>
</section>

<section class="aa-home-clusters outer">
    <div class="aa-home-clusters-inner inner">
        {{#get "posts" filter="tag:strategy" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Selezione</span>
                            <h2 class="aa-cluster-title">Tecnologia e digitale</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/strategy/">Vai all'archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:transformation" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Selezione</span>
                            <h2 class="aa-cluster-title">Innovazione e cambiamento</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/transformation/">Vai all'archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:ai" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Selezione</span>
                            <h2 class="aa-cluster-title">Taccuino tecnico</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/ai/">Vai all'archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}
    </div>
</section>
