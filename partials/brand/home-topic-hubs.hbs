<section class="aa-home-clusters outer">
    <div class="aa-home-clusters-inner inner">
        {{#get "posts" filter="tag:intelligenza-artificiale" limit="3" include="tags"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Intelligenza Artificiale</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/intelligenza-artificiale/">Archivio Intelligenza Artificiale</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:innovazione" limit="3" include="tags"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Innovazione e cambiamento</h2>
                        </div>
                        <a class="aa-text-link" href="/tag/innovazione/">Archivio Innovazione</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:hash-tech-scratchpad" limit="7" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster aa-scratchpad-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">Appunti e guide tecnologiche</h2>
                        </div>
                        <a class="aa-text-link" href="/tech-scratchpad/">Archivio completo →</a>
                    </header>
                    <div class="aa-scratchpad-log" role="list">
                        {{#foreach posts}}
                            <a class="aa-scratchpad-log-row" href="{{url}}" role="listitem">
                                <div class="aa-scratchpad-log-badges">
                                    {{> "brand/scratchpad-badges"}}
                                </div>
                                <span class="aa-scratchpad-log-title">{{title}}</span>
                                <time class="aa-scratchpad-log-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                            </a>
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}
    </div>
</section>
