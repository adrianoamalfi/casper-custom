<section class="aa-home-topics outer">
    <div class="aa-home-topics-inner inner">
        <header class="aa-home-section-heading">
            <span class="aa-page-eyebrow">Percorsi</span>
            <h2 class="aa-home-section-title">{{#if @custom.home_topics_title}}{{@custom.home_topics_title}}{{else}}Mappa editoriale{{/if}}</h2>
            <p class="aa-home-section-copy">{{#if @custom.home_topics_description}}{{@custom.home_topics_description}}{{else}}Tre accessi tematici per leggere il sito per ambiti, priorità e casi di applicazione.{{/if}}</p>
        </header>

        <div class="aa-topic-hub-grid">
            <a class="aa-topic-hub" href="{{#if @custom.home_topic_1_url}}{{@custom.home_topic_1_url}}{{else}}/tag/strategy/{{/if}}">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">{{#if @custom.home_topic_1_label}}{{@custom.home_topic_1_label}}{{else}}Tecnologia e sistemi{{/if}}</h3>
                <p class="aa-topic-hub-copy">{{#if @custom.home_topic_1_description}}{{@custom.home_topic_1_description}}{{else}}Analisi su tecnologie, architetture digitali e AI, con attenzione a impatti, maturità operativa e utilità effettiva.{{/if}}</p>
            </a>

            <a class="aa-topic-hub" href="{{#if @custom.home_topic_2_url}}{{@custom.home_topic_2_url}}{{else}}/tag/transformation/{{/if}}">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">{{#if @custom.home_topic_2_label}}{{@custom.home_topic_2_label}}{{else}}Innovazione e cambiamento{{/if}}</h3>
                <p class="aa-topic-hub-copy">{{#if @custom.home_topic_2_description}}{{@custom.home_topic_2_description}}{{else}}Strategia, governance e trasformazione organizzativa lette dal punto di vista dell'esecuzione e della tenuta dei sistemi.{{/if}}</p>
            </a>

            <a class="aa-topic-hub" href="{{#if @custom.home_topic_3_url}}{{@custom.home_topic_3_url}}{{else}}/tag/ai/{{/if}}">
                <span class="aa-topic-hub-kicker">Archivio</span>
                <h3 class="aa-topic-hub-title">{{#if @custom.home_topic_3_label}}{{@custom.home_topic_3_label}}{{else}}Taccuino operativo{{/if}}</h3>
                <p class="aa-topic-hub-copy">{{#if @custom.home_topic_3_description}}{{@custom.home_topic_3_description}}{{else}}Note tecniche, configurazioni e prove di lavoro raccolte come documentazione essenziale.{{/if}}</p>
            </a>
        </div>
    </div>
</section>

<section class="aa-home-clusters outer">
    <div class="aa-home-clusters-inner inner">
        {{#get "posts" filter="tag:strategy" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">{{#if @custom.home_topic_1_label}}{{@custom.home_topic_1_label}}{{else}}Tecnologia e sistemi{{/if}}</h2>
                        </div>
                        <a class="aa-text-link" href="{{#if @custom.home_topic_1_url}}{{@custom.home_topic_1_url}}{{else}}/tag/strategy/{{/if}}">Archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:transformation" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">{{#if @custom.home_topic_2_label}}{{@custom.home_topic_2_label}}{{else}}Innovazione e cambiamento{{/if}}</h2>
                        </div>
                        <a class="aa-text-link" href="{{#if @custom.home_topic_2_url}}{{@custom.home_topic_2_url}}{{else}}/tag/transformation/{{/if}}">Archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "posts" filter="tag:ai" limit="3" include="tags,authors"}}
            {{#if posts}}
                <section class="aa-cluster">
                    <header class="aa-cluster-header">
                        <div>
                            <span class="aa-page-eyebrow">Focus</span>
                            <h2 class="aa-cluster-title">{{#if @custom.home_topic_3_label}}{{@custom.home_topic_3_label}}{{else}}Taccuino operativo{{/if}}</h2>
                        </div>
                        <a class="aa-text-link" href="{{#if @custom.home_topic_3_url}}{{@custom.home_topic_3_url}}{{else}}/tag/ai/{{/if}}">Archivio</a>
                    </header>
                    <div class="aa-cluster-feed">
                        {{#foreach posts}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/if}}
        {{/get}}
    </div>
</section>
