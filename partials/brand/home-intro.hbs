<section class="aa-intro outer">
    <div class="aa-intro-inner inner">
        {{#if @site.description}}
            <p class="aa-intro-tagline">{{@site.description}}</p>
        {{/if}}

        <div class="aa-intro-actions">
            <a class="aa-intro-link" href="/about">Chi sono &rarr;</a>
            <a class="aa-intro-link is-secondary" href="/tag/strategy/">Esplora i contenuti</a>
        </div>

        <div class="aa-focus-grid" aria-label="Editorial focus">
            <article class="aa-focus-card">
                <span class="aa-focus-kicker">Blocco 01</span>
                <h2 class="aa-focus-title">Nuove tecnologie</h2>
                <p class="aa-focus-copy">Post in cui leggo le tecnologie emergenti in chiave strategica, le spiego e ne valuto impatto, maturità e implicazioni reali.</p>
            </article>

            <article class="aa-focus-card">
                <span class="aa-focus-kicker">Blocco 02</span>
                <h2 class="aa-focus-title">Innovazione e cambiamento</h2>
                <p class="aa-focus-copy">La gestione dell’innovazione, del cambiamento e dei suoi impatti su organizzazione, processi, ruoli e modelli operativi.</p>
            </article>

            <article class="aa-focus-card">
                <span class="aa-focus-kicker">Blocco 03</span>
                <h2 class="aa-focus-title">Taccuino tecnico</h2>
                <p class="aa-focus-copy">How-to, appunti pratici, esperimenti e articoli più operativi su come si fanno davvero alcune cose.</p>
            </article>
        </div>
    </div>
</section>
