<section class="aa-post-cta gh-canvas">
    <div class="aa-post-cta-inner">
        <span class="aa-page-eyebrow">{{t "Approfondimenti"}}</span>
        <h2 class="aa-post-cta-title">{{#if @custom.post_cta_title}}{{@custom.post_cta_title}}{{else}}{{t "Continua l'esplorazione"}}{{/if}}</h2>
        <p class="aa-post-cta-copy">{{#if @custom.post_cta_copy}}{{@custom.post_cta_copy}}{{else}}{{t "Una selezione di percorsi, profilo professionale e possibilità di confronto collegati ai temi trattati nel sito."}}{{/if}}</p>

        <div class="aa-post-cta-actions">
            <a class="aa-primary-button" href="{{#if @custom.post_cta_primary_url}}{{@custom.post_cta_primary_url}}{{else}}/contact-me/{{/if}}">
                {{t "Contattami"}}
            </a>
            <a class="aa-text-link" href="/about/">
                {{t "Profilo"}}
            </a>
        </div>
    </div>
</section>
