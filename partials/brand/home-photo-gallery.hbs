<section class="aa-home-photos outer">
    <div class="aa-home-photos-inner inner">
        <header class="aa-home-section-heading">
            <span class="aa-page-eyebrow">Visuale</span>
            <h2 class="aa-home-section-title">{{#if @custom.home_visual_title}}{{@custom.home_visual_title}}{{else}}Archivio visuale{{/if}}</h2>
            <p class="aa-home-section-copy">{{#if @custom.home_visual_description}}{{@custom.home_visual_description}}{{else}}Una sezione dedicata a fotografie e immagini generate, ordinata come parte del medesimo impianto editoriale.{{/if}}</p>
        </header>

        <div class="aa-visual-columns">
            {{#get "posts" filter="tag:hash-photos" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">{{#if @custom.home_photos_label}}{{@custom.home_photos_label}}{{else}}Fotografie{{/if}}</span>
                                <h3 class="aa-cluster-title">{{#if @custom.home_photos_title}}{{@custom.home_photos_title}}{{else}}Fotografie{{/if}}</h3>
                            </div>
                            <a class="aa-text-link" href="{{#if @custom.home_photos_url}}{{@custom.home_photos_url}}{{else}}/photos/{{/if}}">Archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}

            {{#get "posts" filter="tag:hash-ai-art" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">{{#if @custom.home_ai_label}}{{@custom.home_ai_label}}{{else}}Immagini generate{{/if}}</span>
                                <h3 class="aa-cluster-title">{{#if @custom.home_ai_title}}{{@custom.home_ai_title}}{{else}}Immagini generate{{/if}}</h3>
                            </div>
                            <a class="aa-text-link" href="{{#if @custom.home_ai_url}}{{@custom.home_ai_url}}{{else}}/ai-art/{{/if}}">Archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>
