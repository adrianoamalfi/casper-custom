<section class="aa-home-photos outer">
    <div class="aa-home-photos-inner inner">
        <header class="aa-home-section-heading">
            <span class="aa-page-eyebrow">Visuale</span>
            <h2 class="aa-home-section-title">Archivio visuale</h2>
            <p class="aa-home-section-copy">Una sezione dedicata a fotografie e immagini generate, ordinata come parte del medesimo impianto editoriale.</p>
        </header>

        <div class="aa-visual-columns">
            {{#get "posts" filter="tag:hash-photos" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">Fotografie</span>
                                <h3 class="aa-cluster-title">Fotografie</h3>
                            </div>
                            <a class="aa-text-link" href="/photos/">Archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}

            {{#get "posts" filter="tag:hash-ai-art-and-images" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">Immagini generate</span>
                                <h3 class="aa-cluster-title">Immagini generate</h3>
                            </div>
                            <a class="aa-text-link" href="/ai-art/">Archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>
