<section class="aa-home-photos outer">
    <div class="aa-home-photos-inner inner">
        <header class="aa-home-section-heading">
            <span class="aa-page-eyebrow">Area visuale</span>
            <h2 class="aa-home-section-title">Fotografie e immagini generate</h2>
            <p class="aa-home-section-copy">Accanto alla scrittura tengo un archivio visivo separato. Da una parte le fotografie che scatto, dall’altra le immagini generate con l’AI come spazio di esplorazione più libero e sperimentale.</p>
        </header>

        <div class="aa-visual-columns">
            {{#get "posts" filter="tag:hash-photos" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">Fotografie</span>
                                <h3 class="aa-cluster-title">Scatti personali</h3>
                            </div>
                            <a class="aa-text-link" href="/photos/">Vai all'archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}

            {{#get "posts" filter="tag:hash-ai-art" limit="6" include="tags,authors"}}
                {{#if posts}}
                    <section class="aa-visual-column">
                        <header class="aa-visual-column-header">
                            <div>
                                <span class="aa-page-eyebrow">Immagini generate</span>
                                <h3 class="aa-cluster-title">Immagini generate con l’AI</h3>
                            </div>
                            <a class="aa-text-link" href="/ai-art/">Vai all'archivio</a>
                        </header>

                        <div class="aa-home-photo-grid">
                            {{#foreach posts}}
                                {{> "brand/home-photo-thumb"}}
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>
