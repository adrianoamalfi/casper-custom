{{!-- This is a partial file used to generate a post "card"
which templates loop over to generate a list of posts. --}}

<article class="post-card {{post_class}}{{#match @custom.feed_layout "Classic"}}{{#is "home"}}{{#has index="0"}} post-card-large{{/has}}{{#has index="1,2"}} dynamic{{/has}}{{/is}}{{/match}}{{#match @custom.feed_layout "Grid"}} keep-ratio{{/match}}{{#match @custom.feed_layout "List"}}{{^is "tag, author"}} post-card-large{{/is}}{{/match}}{{#unless access}} post-access-{{visibility}}{{/unless}}">

    {{#if feature_image}}
    <a class="post-card-image-link" href="{{url}}">
        {{#has index="0"}}
            {{!-- First card is the likely LCP candidate: load eagerly with high priority --}}
            {{> "media/picture-card"
                image=feature_image
                picture_class="aa-responsive-picture aa-post-card-picture"
                img_class="post-card-image"
                sizes="(max-width: 767px) calc(100vw - 32px), (max-width: 1200px) calc(50vw - 40px), 880px"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                image_alt=feature_image_alt
                alt=title
            }}
        {{else}}
            {{> "media/picture-card"
                image=feature_image
                picture_class="aa-responsive-picture aa-post-card-picture"
                img_class="post-card-image"
                sizes="(max-width: 767px) calc(100vw - 32px), (max-width: 1200px) calc(50vw - 40px), 880px"
                loading="lazy"
                decoding="async"
                image_alt=feature_image_alt
                alt=title
            }}
        {{/has}}

        {{#unless access}}
        {{^has visibility="public"}}
            <div class="post-card-access">
                {{> "icons/lock"}}
                {{#has visibility="members"}}
                    {{t "Members only"}}
                {{else}}
                    {{t "Paid-members only"}}
                {{/has}}
            </div>
        {{/has}}
        {{/unless}}

    </a>
    {{/if}}

    <div class="post-card-content">

        <a class="post-card-content-link" href="{{url}}">
            <header class="post-card-header">
                {{#has tag="hash-tech-scratchpad"}}
                    {{> "brand/scratchpad-badges"}}
                {{else}}
                    <div class="post-card-tags">
                        {{#primary_tag}}
                            <span class="post-card-primary-tag">{{name}}</span>
                        {{/primary_tag}}
                        {{#if featured}}
                            <span class="post-card-featured">{{> "icons/fire"}} {{t "Featured"}}</span>
                        {{/if}}
                    </div>
                {{/has}}
                <h2 class="post-card-title">
                    {{#unless access}}
                    {{^has visibility="public"}}
                        {{#unless feature_image}}
                            {{> "icons/lock"}}
                        {{/unless}}
                    {{/has}}
                    {{/unless}}
                    {{title}}
                </h2>
            </header>
            {{#if excerpt}}
                <div class="post-card-excerpt">{{excerpt}}</div>
            {{/if}}
        </a>

        <footer class="post-card-meta">
            <time class="post-card-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
            {{#if reading_time}}
                <span class="post-card-meta-length">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
            {{/if}}
            {{#if @site.comments_enabled}}
                {{comment_count}}
            {{/if}}
        </footer>
        {{#has tag="hash-tech-scratchpad"}}
            {{> "brand/scratchpad-stacks"}}
        {{/has}}

    </div>

</article>
